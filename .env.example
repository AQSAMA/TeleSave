BOT_TOKEN=123456:replace-me
APP_ENV=production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=7860

# Fallback Option A: hosted Telegram Bot API
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_LOCAL_MODE=false

# Option B: local Telegram Bot API server (recommended for uploads up to 2 GB)
# TELEGRAM_API_BASE_URL=http://127.0.0.1:8081
# TELEGRAM_LOCAL_MODE=true
# TELEGRAM_API_ID=replace-with-api-id
# TELEGRAM_API_HASH=replace-with-api-hash

MAX_FILE_SIZE_MB=1900
MAX_DOWNLOAD_SECONDS=900
MAX_CONCURRENT_DOWNLOADS=2
MAX_CONCURRENT_DOWNLOADS_PER_USER=1
TEMP_DIR=/tmp/telesave
CLEANUP_AFTER_SECONDS=3600

YTDLP_COOKIES_FILE=
YTDLP_USER_AGENT=
YTDLP_FORMAT=
YTDLP_PROXY=

DIRECT_DOWNLOAD_CONNECT_TIMEOUT=10
DIRECT_DOWNLOAD_READ_TIMEOUT=60
DIRECT_DOWNLOAD_MAX_REDIRECTS=5
DIRECT_DOWNLOAD_CHUNK_SIZE=1048576
